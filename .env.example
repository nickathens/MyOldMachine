# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === LLM Provider ===
# Options: claude, claude-cli, claude-api, openai, gemini, ollama, openrouter
#
# "claude" (default): Uses Claude Code CLI with full tool-use (bash, file ops, etc.)
#   - Requires `claude` CLI installed (npm install -g @anthropic-ai/claude-code)
#   - No API key needed (uses Claude Code's own auth)
#   - This is how the bot actually controls the machine
#
# "claude-api": Uses Anthropic API directly (no tool-use, text-only)
#   - Requires LLM_API_KEY
#   - Good for cheaper/simpler chat without machine control
#
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=

# For Ollama (local, free):
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# For OpenAI:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# For OpenRouter (many models, one API key):
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# LLM_API_KEY=sk-or-...

# For Google Gemini:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=...

# === Security ===
# Comma-separated Telegram user IDs allowed to use the bot (empty = anyone)
ALLOWED_USERS=

# === Personalization ===
# Bot display name
BOT_NAME=MyOldMachine

# Timezone for scheduling (IANA format)
TIMEZONE=UTC

# === Advanced ===
# Webhook server port (0 to disable, use polling)
WEBHOOK_PORT=0

# Local Telegram Bot API (for >20MB file uploads, optional)
# TELEGRAM_API_BASE=http://localhost:8081
