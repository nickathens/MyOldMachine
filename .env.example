# === Required ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === LLM Provider ===
# Options: claude, claude-api, openai, gemini, ollama, openrouter
#
# "claude" (default): Claude Code CLI with full tool-use (bash, files, web)
#   - Requires `claude` CLI installed: npm install -g @anthropic-ai/claude-code
#   - Then run: claude login
#   - No API key needed. This is how the bot controls the machine.
#
# "claude-api": Anthropic API directly (text-only, no tool-use)
#   - Requires LLM_API_KEY
#   - Good for cheaper/simpler chat without machine control
#
# All other providers (openai, gemini, openrouter) are text-only and require API keys.
# Ollama is free and local — no API key needed.
#
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=

# For Ollama (local, free):
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# For OpenAI:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# For OpenRouter (many models, one API key — free models available):
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_API_KEY=sk-or-...
# Free model IDs end with :free. See: https://openrouter.ai/models?q=free
# Other free options: google/gemma-3-27b-it:free, qwen/qwen3-coder:free

# For Google Gemini (NOTE: free tier often has zero quota — consider OpenRouter instead):
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY=...

# === Security ===
# Comma-separated Telegram user IDs allowed to use the bot (empty = anyone)
ALLOWED_USERS=

# === Personalization ===
# Bot display name
BOT_NAME=MyOldMachine

# Timezone for scheduling (IANA format)
TIMEZONE=UTC

# === Advanced ===
# Webhook server port (0 to disable, use polling)
WEBHOOK_PORT=0

# Local Telegram Bot API (for >20MB file uploads, optional)
# TELEGRAM_API_BASE=http://localhost:8081
